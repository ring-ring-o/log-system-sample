{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "gen:errors": "uv run --package flownote-api flownote-error-catalog --format ts -o src/shared/error-catalog.generated.ts",
    "check:errors": "uv run --package flownote-api flownote-error-catalog --format ts --check src/shared/error-catalog.generated.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@flownote/observability-web": "workspace:*",
    "next": "16.0.0-beta.0",
    "next-auth": "5.0.0-beta.31",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

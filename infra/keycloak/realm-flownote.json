{
  "realm": "flownote",
  "enabled": true,
  "displayName": "FlowNote",
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "viewer", "description": "閲覧・検索のみ" },
      { "name": "editor", "description": "作成・更新・AI利用" },
      { "name": "admin", "description": "削除・管理・監査閲覧" }
    ]
  },
  "clients": [
    {
      "clientId": "flownote-web",
      "name": "FlowNote Web (フロントエンド)",
      "enabled": true,
      "publicClient": false,
      "secret": "flownote-web-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-flownote-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "flownote-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "flownote-api",
      "name": "FlowNote API (バックエンド)",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Editor",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["editor"]
    },
    {
      "username": "admin-user",
      "enabled": true,
      "email": "admin@example.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["admin", "editor"]
    },
    {
      "username": "viewer-user",
      "enabled": true,
      "email": "viewer@example.com",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["viewer"]
    }
  ]
}

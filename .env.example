# FlowNote 環境変数のサンプル。`.env` にコピーして使う(秘密はコミットしない)。
# 既定値は外部依存なしのローカル実行(sqlite + AIスタブ + dev認証)を想定。

# --- 実行環境 ---
FLOWNOTE_ENV=local
FLOWNOTE_LOG_LEVEL=DEBUG
# 1 でトレース/メトリクスをコンソールにも出力(ローカル観察用)。
FLOWNOTE_OTEL_CONSOLE=1
# OTel Collector へ送る場合に設定(未設定ならコンソールのみ)。
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- DB ---
# ローカル既定は sqlite。compose では postgresql+psycopg を使う。
FLOWNOTE_REPO_BACKEND=sql
FLOWNOTE_DATABASE_URL=sqlite+aiosqlite:///./.tmp/flownote.db

# --- AI ---
# stub(外部不要) / openai(OpenAI互換サーバ or ai-mock)。
FLOWNOTE_AI_BACKEND=stub
FLOWNOTE_AI_BASE_URL=http://localhost:8001
FLOWNOTE_AI_CHAT_MODEL=qwen2.5-instruct
FLOWNOTE_AI_EMBEDDING_MODEL=qwen2.5-embed

# --- 認証 ---
# dev(Keycloak不要) / oidc(Keycloak)。
FLOWNOTE_AUTH_MODE=dev
FLOWNOTE_OIDC_JWKS_URL=http://localhost:8080/realms/flownote/protocol/openid-connect/certs
FLOWNOTE_OIDC_ISSUER=http://localhost:8080/realms/flownote
FLOWNOTE_OIDC_AUDIENCE=flownote-api

# --- フロントエンド(Next.js / Auth.js)---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_OTLP_ENDPOINT=http://localhost:4318
NEXT_PUBLIC_DEPLOYMENT_ENV=local
# 開発専用: Keycloak を立てない場合の API dev 認証トークン(例 alice:editor)。
# 本番ビルドでは絶対に設定しないこと(クライアントバンドルに焼き込まれる)。dev ビルドのみ有効。
# NEXT_PUBLIC_DEV_TOKEN=alice:editor
AUTH_SECRET=change-me-in-prod
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/flownote
AUTH_KEYCLOAK_ID=flownote-web
AUTH_KEYCLOAK_SECRET=flownote-web-dev-secret

# FlowNote AI Mock — マルチステージビルド(軽量ランタイム)。

FROM ghcr.io/astral-sh/uv:python3.14-bookworm-slim AS builder
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy
WORKDIR /app
COPY pyproject.toml uv.lock ./
COPY packages ./packages
COPY apps/ai-mock ./apps/ai-mock
COPY apps/api/pyproject.toml ./apps/api/pyproject.toml
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --package flownote-ai-mock --no-dev --frozen

FROM python:3.14-slim-bookworm AS runtime
RUN useradd --create-home --uid 1000 app
WORKDIR /app
COPY --from=builder --chown=app:app /app/.venv /app/.venv
COPY --from=builder --chown=app:app /app/apps/ai-mock/src /app/apps/ai-mock/src
ENV PATH="/app/.venv/bin:$PATH"
USER app
EXPOSE 8001
CMD ["uvicorn", "flownote_ai_mock.main:app", "--host", "0.0.0.0", "--port", "8001"]
